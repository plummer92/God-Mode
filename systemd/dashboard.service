[Unit]
Description=Wolfe Dashboard
After=network.target

[Service]
Type=simple
User=theplummer92
WorkingDirectory=/home/theplummer92
ExecStart=/home/theplummer92/venv/bin/python3 -m streamlit run /home/theplummer92/dashboard_db.py --server.port 8501 --server.headless true
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
