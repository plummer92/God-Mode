[Unit]
Description=Wolfe Strategy Lab one-shot run
After=network.target

[Service]
Type=oneshot
User=theplummer92
Environment=GOD_MODE_DATA_DIR=/home/theplummer92
Environment=GOD_MODE_ENV_FILE=/home/theplummer92/.env
WorkingDirectory=/home/theplummer92/god-mode-sync
ExecStart=/home/theplummer92/venv/bin/python3 /home/theplummer92/god-mode-sync/strategy_lab.py --once
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
